{
  "compilerOptions": {
    "target": "ES2020",

    "module": "commonjs",
    "moduleResolution": "node",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "verbatimModuleSyntax": false,

    "ignoreDeprecations": "6.0"
  },

  "include": ["src"],

  "exclude": ["node_modules"]
}